# ── Gemini API (필수) ─────────────────────────────────────────────────────────
API_KEY=your_gemini_api_key_here

# ── Serper.dev — Google SERP 실측 데이터 ──────────────────────────────────────
VITE_SERPER_API_KEY=your_serper_api_key_here

# ── Naver Search API + DataLab 검색어트렌드 (선택) ────────────────────────────
# 동일한 Client ID/Secret으로 검색 API + DataLab 트렌드 API 모두 사용 가능
VITE_NAVER_CLIENT_ID=여기에_Client_ID_입력
VITE_NAVER_CLIENT_SECRET=여기에_Client_Secret_입력

# ── Naver 검색광고 API — 키워드 볼륨 (선택, 사업자 계정 필요) ────────────────────
VITE_NAVER_AD_API_KEY=
VITE_NAVER_AD_SECRET=
VITE_NAVER_AD_CUSTOMER_ID=
